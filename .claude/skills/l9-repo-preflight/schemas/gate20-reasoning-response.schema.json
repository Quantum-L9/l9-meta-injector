{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.example/schemas/gate20-reasoning-response.schema.json",
  "title": "Gate 20B Reasoning Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_digest", "conclusions", "prioritized_actions", "challenged_findings", "unresolved_questions", "confidence", "references_to_known_finding_ids"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "evidence_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "conclusions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["summary", "supported_by"],
        "properties": {
          "summary": {"type": "string", "minLength": 1},
          "supported_by": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    },
    "prioritized_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "action", "addresses", "rationale"],
        "properties": {
          "priority": {"type": "integer", "minimum": 1},
          "action": {"type": "string", "minLength": 1},
          "addresses": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    },
    "challenged_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "reason"],
        "properties": {
          "finding_id": {"type": "string"},
          "proposed_status": {"not": {"enum": ["clear", "not_applicable"]}},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "unresolved_questions": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "references_to_known_finding_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}
