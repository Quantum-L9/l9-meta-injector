{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.example/schemas/preflight-v3.9-report.schema.json",
  "type": "object",
  "required": [
    "version",
    "versions",
    "environment_capability_report",
    "gate_capability_contracts",
    "forensic_audit",
    "preflight_result",
    "findings",
    "full_preflight",
    "semantic_index"
  ],
  "properties": {
    "version": {
      "const": "3.9"
    },
    "versions": {
      "type": "object",
      "required": [
        "skill",
        "evaluator",
        "schema",
        "provider",
        "semantic_index",
        "tree_sitter",
        "environment",
        "gate20"
      ],
      "additionalProperties": false,
      "properties": {
        "skill": {
          "const": "3.9"
        },
        "evaluator": {
          "const": "3.9"
        },
        "schema": {
          "const": "3.9"
        },
        "provider": {
          "const": "3.8"
        },
        "semantic_index": {
          "const": "1.0"
        },
        "tree_sitter": {
          "type": "string"
        },
        "environment": {
          "const": "1.2"
        },
        "gate20": {
          "const": "2.1"
        }
      }
    },
    "environment_capability_report": {
      "$ref": "../config/environment-capabilities.schema.json"
    },
    "gate_capability_contracts": {
      "type": "object",
      "minProperties": 20
    },
    "forensic_audit": {
      "type": "object",
      "required": [
        "static",
        "reasoning",
        "pr_context",
        "provider_resolution",
        "audit_depth",
        "limitations",
        "confidence",
        "evidence_digest"
      ]
    },
    "preflight_result": {
      "type": "object",
      "required": [
        "status",
        "execution_depth",
        "audit_depth",
        "environment_capability_report_ref",
        "limitations",
        "deterministic_status",
        "reasoning_assessment",
        "final_status",
        "confidence"
      ]
    },
    "findings": {
      "type": "array"
    },
    "full_preflight": {
      "type": "boolean"
    },
    "semantic_index": {
      "type": "object",
      "required": [
        "engine",
        "tree_sitter",
        "summary",
        "files_scanned",
        "parse_error_count",
        "artifact_ref"
      ],
      "properties": {
        "engine": {
          "const": "hybrid_semantic_index"
        },
        "tree_sitter": {
          "type": "object"
        },
        "summary": {
          "type": "object"
        },
        "files_scanned": {
          "type": "integer",
          "minimum": 0
        },
        "parse_error_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_ref": {
          "const": "semantic-index.json"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
