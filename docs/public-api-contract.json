{
  "schema": "l9.public-api-contract/v1",
  "repository": "Quantum-L9/l9-meta-injector",
  "package_name": "l9-meta-injector",
  "package_version": "3.0.0",
  "policy": {
    "root_model": "orchestration_first",
    "versioning": "semver",
    "deep_imports": "deny_unlisted",
    "runtime_and_declarations_are_separate_contracts": true
