    "l9-meta-injector/dist/schema",
    "l9-meta-injector/src/schema",
    "l9-meta-injector/dist/public/schema"
  ],
  "caller_obligations_for_experimental_composition": [
    "account for skipped inputs and coverage gaps",
    "aggregate and gate on verification results",
    "preserve body bytes and reconciliation logs",
    "preserve normalization and stage ordering",
    "propagate diagnostics, metrics, and errors",
    "sequence persisted outputs deterministically"
  ]
