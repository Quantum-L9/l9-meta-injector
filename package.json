{
  "name": "l9-meta-injector",
  "version": "2.1.0",
  "description": "L9 meta-injection toolkit for prompt, skill, and kernel metadata",
  "license": "MIT",
  "author": "Quantum-L9",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Quantum-L9/l9-meta-injector.git"
  },
  "homepage": "https://github.com/Quantum-L9/l9-meta-injector#readme",
  "bugs": {
    "url": "https://github.com/Quantum-L9/l9-meta-injector/issues"
  },
  "keywords": [
    "l9",
    "metadata",
    "meta-injection",
    "artifact-metadata",
    "prompt",
    "skill",
    "kernel",
    "mcp",
    "frontmatter",
    "code-annotation",
    "sidecar",
    "yaml"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "examples",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest --config jest.config.js --no-coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "selfpack": "npm run build && node scripts/selfpack.js",
    "selfpack:update": "npm run build && node scripts/selfpack.js --update"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.12",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4"
  }
