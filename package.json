{
  "name": "l9-meta-injector",
  "version": "3.0.0",
  "description": "L9 meta-injection toolkit for prompt, skill, and kernel metadata",
  "license": "MIT",
  "author": "Quantum-L9",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Quantum-L9/l9-meta-injector.git"
  },
  "homepage": "https://github.com/Quantum-L9/l9-meta-injector#readme",
  "bugs": {
    "url": "https://github.com/Quantum-L9/l9-meta-injector/issues"
  },
  "keywords": [
    "l9",
    "metadata",
    "meta-injection",
    "artifact-metadata",
    "prompt",
    "skill",
    "kernel",
    "mcp",
    "frontmatter",
    "code-annotation",
    "sidecar",
    "yaml"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "examples",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "selfpack": "npm run build && node scripts/selfpack.js",
    "selfpack:update": "npm run build && node scripts/selfpack.js --update",
    "inventory": "npm run build && node scripts/inventory.js",
    "check:api": "node scripts/check-public-api.js",
    "check:authority": "node scripts/check-architecture-authority.js",
    "check:manifest": "node scripts/generate-architecture-manifest.js --check",
    "manifest:update": "node scripts/generate-architecture-manifest.js",
    "check:dist": "node scripts/check-dist-sync.js",
    "test:packed": "node scripts/test-packed-consumer.js",
    "check:publication": "node scripts/check-publication-readiness.js",
    "validate": "npm run typecheck && npm test && npm run check:api && npm run check:authority && npm run check:manifest && npm run check:dist && npm run selfpack && npm run test:packed",
    "prepack": "npm run check:api && npm run check:authority && npm run check:manifest && npm run check:dist",
    "prepublishOnly": "npm run validate && npm run check:publication"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "@types/node": "20.19.43",
    "eslint": "^9.39.5",
    "typescript-eslint": "^8.65.0",
    "vitest": "^3.2.7"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./inventory": {
      "types": "./dist/public/inventory.d.ts",
      "require": "./dist/public/inventory.js",
      "default": "./dist/public/inventory.js"
    },
    "./schema": {
      "types": "./dist/public/schema.d.ts",
      "require": "./dist/public/schema.js",
      "default": "./dist/public/schema.js"
    },
    "./advanced": {
      "types": "./dist/public/advanced.d.ts",
      "require": "./dist/public/advanced.js",
      "default": "./dist/public/advanced.js"
    },
    "./advanced/llm": {
      "types": "./dist/public/llm.d.ts",
      "require": "./dist/public/llm.js",
      "default": "./dist/public/llm.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "inventory": [
        "dist/public/inventory.d.ts"
      ],
      "schema": [
        "dist/public/schema.d.ts"
      ],
      "advanced": [
        "dist/public/advanced.d.ts"
      ],
      "advanced/llm": [
        "dist/public/llm.d.ts"
      ]
    }
  }
}
